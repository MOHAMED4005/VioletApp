<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="0dp">

        <include layout="@layout/view_tool_header"
            android:id="@+id/header" />

        <include layout="@layout/view_field_row"
            android:id="@+id/field_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <include layout="@layout/view_field_row"
            android:id="@+id/field_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <!-- Output Format -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OUTPUT FORMAT"
            style="@style/Widget.Violet.SectionLabel"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_format"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_jpg"
                style="@style/Widget.Violet.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JPG"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_png"
                style="@style/Widget.Violet.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PNG" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_webp"
                style="@style/Widget.Violet.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WEBP" />

        </com.google.android.material.chip.ChipGroup>

        <include layout="@layout/view_status_bar"
            android:id="@+id/status_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start"
            style="@style/Widget.Violet.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Start"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>
