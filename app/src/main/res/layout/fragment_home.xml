<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="48dp">

        <!-- Wordmark -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Violet"
            android:textSize="36sp"
            android:textColor="@color/accent2"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Image processing toolkit"
            android:textSize="13sp"
            android:textColor="@color/subtext"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp" />

        <!-- Vertimerge card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_vertimerge"
            style="@style/VioletCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="🔗"
                    android:textSize="26sp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_bubble"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vertimerge"
                        android:textSize="15sp"
                        android:textColor="@color/text"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Merge chapter images vertically"
                        android:textSize="12sp"
                        android:textColor="@color/subtext"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="@color/subtext" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Zip Maker card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_zipmaker"
            style="@style/VioletCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="🗜"
                    android:textSize="26sp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_bubble"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zip Maker"
                        android:textSize="15sp"
                        android:textColor="@color/text"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Package chapters into ZIP archives"
                        android:textSize="12sp"
                        android:textColor="@color/subtext"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="@color/subtext" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Watermark card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_watermark"
            style="@style/VioletCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="🔏"
                    android:textSize="26sp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_bubble"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Watermark"
                        android:textSize="15sp"
                        android:textColor="@color/text"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stamp a logo onto chapter pages"
                        android:textSize="12sp"
                        android:textColor="@color/subtext"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="@color/subtext" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Photo Format Changer card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_formatter"
            style="@style/VioletCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="🎨"
                    android:textSize="26sp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_bubble"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Photo Format Changer"
                        android:textSize="15sp"
                        android:textColor="@color/text"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Batch convert image formats"
                        android:textSize="12sp"
                        android:textColor="@color/subtext"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="@color/subtext" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="All settings are saved automatically"
            android:textSize="11sp"
            android:textColor="@color/subtext" />

    </LinearLayout>
</ScrollView>
